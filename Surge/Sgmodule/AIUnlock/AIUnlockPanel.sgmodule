#!name=AI Unlock Panel
#!desc=按出口地区检测 ChatGPT、Gemini、Claude 等 AI 服务的通常可用性
#!author=Codex
#!arguments=title=AI%20Unlock&services=chatgpt,gemini,claude,copilot,perplexity,grok&icon=brain.head.profile&iconcolor=%237C3AED&iconerr=xmark.seal.fill&iconerrcolor=%23D65C51

# 远程脚本托管于 GitHub；安装此模块后会自动从该地址更新脚本。

[Panel]
AI Unlock = script-name=AIUnlock,update-interval=-1

[Script]
AIUnlock = type=generic,timeout=8,script-path=https://raw.githubusercontent.com/PANGPANGDigital/GoodGoodStudyDayDayUp/refs/heads/main/Surge/Sgmodule/AIUnlock/AIUnlockPanel.js,script-update-interval=86400,argument=title=%title%&services=%services%&icon=%icon%&icon-color=%iconcolor%&iconerr=%iconerr%&iconerr-color=%iconerrcolor%
